<plist version="1.0">
<dict>
	<key>__xctestrun_metadata__</key>
	<dict>
		<key>FormatVersion</key>
		<integer>1</integer>
	</dict>
	<key>iOSControlAgentUITests</key>
	<dict>
		<key>BlueprintName</key>
		<string>iOSControlAgentUITests</string>
		<key>TestHostBundleIdentifier</key>
		<string>com.ioscontrol.agent.xctrunner</string>
		<key>TestHostPath</key>
		<string>__TESTHOST__/iOSControlAgent.app</string>
		<key>TestBundlePath</key>
		<string>__TESTHOST__/iOSControlAgent.app/PlugIns/iOSControlAgentUITests.xctest</string>
